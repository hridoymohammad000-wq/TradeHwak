APP_NAME=TradeHawk Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
DEFAULT_SYSTEM_MODE=demo
DEFAULT_STRATEGY_MODE=scalping

# Required private access token. Generate a unique random value of at least 32 characters.
# Keep the real value only in backend/.env or the deployment platform's secret manager.
TRADEHAWK_ACCESS_TOKEN=
TRADEHAWK_SESSION_TTL_MINUTES=480
TRADEHAWK_SESSION_COOKIE_NAME=tradehawk_session
TRADEHAWK_SESSION_COOKIE_SECURE=false
TRADEHAWK_SESSION_COOKIE_SAMESITE=lax

# Security lock: keep TradeHawk on Bybit Demo Trading only.
BYBIT_ENV=demo
BYBIT_BASE_URL=https://api-demo.bybit.com

# Backend-only credentials. Never prefix these variables with VITE_ and never place them in frontend files.
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

RUNTIME_STATE_PATH=outputs/runtime-state.json

# Optional backend-only Supabase persistence. Configure both values together or leave both blank.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RUNTIME_TABLE=runtime_state
SUPABASE_RUNTIME_ROW_KEY=primary
SUPABASE_TIMEOUT_SECONDS=8
